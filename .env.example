# Env vars for Remnawave panel connection
# Copy to .env and fill in values

APP_PORT=3010

# Remnawave Panel URL — can be http://remnawave:3000 or https://panel.example.com
REMNAWAVE_PANEL_URL=https://remnawave:3000

# API Token — Create in Remnawave Dashboard → Settings → API Tokens
REMNAWAVE_API_TOKEN=

# JWT secret for session cookies (auto-generated if empty)
INTERNAL_JWT_SECRET=change-me-to-a-random-string

# Custom sub prefix (without leading/trailing slashes)
CUSTOM_SUB_PREFIX=

# Express-compatible trust proxy setting
TRUST_PROXY=1

# Subpage config UUID (use 'default' for auto)
SUBPAGE_CONFIG_UUID=default
